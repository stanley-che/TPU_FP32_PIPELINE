// tb_tile_stats_edge_4x4_like_linebuf.sv
// ------------------------------------------------------------
// Build:
//   iverilog -g2012 -Wall -I./src -o ./vvp/tb_tile_stats_edge_4x4.vvp ./test/tb_tile_stats_edge_4x4.sv
// Run:
//   vvp ./vvp/tb_tile_stats_edge_4x4.vvp
// Wave:
//   gtkwave ./vvp/tb_tile_stats_edge_4x4.vcd
// ------------------------------------------------------------


`timescale 1ns/1ps
`default_nettype none

module tile_stats_4x4 #(
  parameter int unsigned Y_W      = 8,
  parameter int unsigned TILE_W   = 4,
  parameter int unsigned TILE_H   = 4,

  // ---- feature switches ----
  parameter bit          SUPPORT_PIX_VALID = 1'b1,  // pix_in_tile_valid
  parameter bit          DO_SUMSQ           = 1'b0, // optional (not used in TB now)
  parameter bit          SATURATE_SUM       = 1'b0, // optional
  parameter bit          SATURATE_SUMSQ     = 1'b0, // optional
  parameter bit          ASSERT_ON          = 1'b1
)(
  input  logic                  clk,
  input  logic                  rst,

  // inputs (v2)
  input  logic                  v2_valid,
  input  logic [Y_W-1:0]         y_in,
  input  logic [$clog2(TILE_W)-1:0] x_mod,
  input  logic [$clog2(TILE_H)-1:0] y_mod,
  input  logic                  tile_last,
  input  logic [15:0]            y_cur,

  input  logic                  pix_in_tile_valid,

  input  logic [15:0]            tile_x_idx,
  input  logic [15:0]            tile_y_idx,
  input  logic [15:0]            frame_id,

  // outputs (v3) with ready/valid
  output logic                  v3_valid,
  input  logic                  v3_ready,

  output logic [SUM_W-1:0]       sumY,
  output logic [Y_W-1:0]         minY,
  output logic [Y_W-1:0]         maxY,

  output logic [Y_W-1:0]         meanY,
  output logic [Y_W-1:0]         rangeY,

  output logic [SUMSQ_W-1:0]     sumSq,

  output logic [15:0]            y_cur_o,
  output logic [15:0]            tile_x_o,
  output logic [15:0]            tile_y_o,
  output logic [15:0]            frame_id_o,

  output logic                  tile_err,
  output logic [7:0]            err_code,
  output logic [$clog2(TILE_W*TILE_H+1)-1:0] pix_cnt_o,
  output logic                  overflow_sum,
  output logic                  overflow_sumsq
);

  // ----------------------------------------------------------------
  // derived widths
  // ----------------------------------------------------------------
  localparam int unsigned TILE_PIXELS = TILE_W * TILE_H;

  localparam int unsigned SUM_MAX      = TILE_PIXELS * ((1<<Y_W) - 1);
  localparam int unsigned SUM_W_LOCAL  = (SUM_MAX <= 1) ? 1 : $clog2(SUM_MAX + 1);
  localparam int unsigned SUM_W        = SUM_W_LOCAL;

  localparam int unsigned SUMSQ_MAX     = TILE_PIXELS * (((1<<Y_W)-1) * ((1<<Y_W)-1));
  localparam int unsigned SUMSQ_W_LOCAL = (SUMSQ_MAX <= 1) ? 1 : $clog2(SUMSQ_MAX + 1);
  localparam int unsigned SUMSQ_W       = SUMSQ_W_LOCAL;

  // ----------------------------------------------------------------
  // helpers
  // ----------------------------------------------------------------
  wire is_tile_first = (x_mod == '0) && (y_mod == '0);
  wire pix_ok        = v2_valid && (SUPPORT_PIX_VALID ? pix_in_tile_valid : 1'b1);
  wire out_hold      = v3_valid && !v3_ready;

  // extend
  logic [SUM_W-1:0]   y_ext_sum;
  logic [SUMSQ_W-1:0] y_sq;

  always_comb begin
    y_ext_sum = {{(SUM_W-Y_W){1'b0}}, y_in};
    y_sq      = '0;
    if (DO_SUMSQ) y_sq = y_in * y_in;
  end

  // ----------------------------------------------------------------
  // running accumulators
  // ----------------------------------------------------------------
  logic [SUM_W-1:0]   sum_r;
  logic [Y_W-1:0]     min_r, max_r;
  logic [SUMSQ_W-1:0] sumsq_r;

  logic in_tile;
  logic [$clog2(TILE_PIXELS+1)-1:0] pix_cnt; // index of current pixel (0..15)

  logic ov_sum_r, ov_sumsq_r;

  // ----------------------------------------------------------------
  // final-computed values for "this pixel" (include current pixel)
  // (computed combinationally; used for latch on tile_last)
  // ----------------------------------------------------------------
  logic [SUM_W-1:0]   sum_final;
  logic [Y_W-1:0]     min_final, max_final;
  logic [SUMSQ_W-1:0] sumsq_final;
  logic [$clog2(TILE_PIXELS+1)-1:0] pix_cnt_eff;

  always_comb begin
    // "this pixel index"
    pix_cnt_eff = is_tile_first ? '0 : (pix_cnt + 1'b1);

    if (is_tile_first) begin
      sum_final  = y_ext_sum;
      min_final  = y_in;
      max_final  = y_in;
      sumsq_final= (DO_SUMSQ) ? y_sq : '0;
    end else begin
      sum_final  = sum_r + y_ext_sum;
      min_final  = (y_in < min_r) ? y_in : min_r;
      max_final  = (y_in > max_r) ? y_in : max_r;
      sumsq_final= (DO_SUMSQ) ? (sumsq_r + y_sq) : sumsq_r;
    end
  end

  // ----------------------------------------------------------------
  // output regs (latched at tile_last, held by v3_ready)
  // ----------------------------------------------------------------
  logic [SUM_W-1:0]   sum_out_r;
  logic [Y_W-1:0]     min_out_r, max_out_r;
  logic [SUMSQ_W-1:0] sumsq_out_r;

  logic [15:0] ycur_out_r, tx_out_r, ty_out_r, fid_out_r;
  logic        v_out_r;

  logic        tile_err_r;
  logic [7:0]  err_code_r;
  logic [$clog2(TILE_PIXELS+1)-1:0] pix_cnt_out_r;

  logic ov_sum_out_r, ov_sumsq_out_r;

  // ----------------------------------------------------------------
  // sequential
  // ----------------------------------------------------------------
  always_ff @(posedge clk) begin
    if (rst) begin
      sum_r   <= '0;
      min_r   <= {Y_W{1'b1}};
      max_r   <= '0;
      sumsq_r <= '0;

      in_tile <= 1'b0;
      pix_cnt <= '0;

      ov_sum_r   <= 1'b0;
      ov_sumsq_r <= 1'b0;

      sum_out_r   <= '0;
      min_out_r   <= '0;
      max_out_r   <= '0;
      sumsq_out_r <= '0;

      ycur_out_r  <= '0;
      tx_out_r    <= '0;
      ty_out_r    <= '0;
      fid_out_r   <= '0;

      v_out_r       <= 1'b0;
      tile_err_r    <= 1'b0;
      err_code_r    <= 8'h00;
      pix_cnt_out_r <= '0;

      ov_sum_out_r   <= 1'b0;
      ov_sumsq_out_r <= 1'b0;

    end else begin
      // hold v_out_r/data until accepted
      if (!out_hold) v_out_r <= 1'b0;

      // clear error at tile_first
      if (pix_ok && is_tile_first) begin
        tile_err_r <= 1'b0;
        err_code_r <= 8'h00;
      end

      if (pix_ok) begin

        // ---- update running accumulators ----
        if (is_tile_first) begin
          in_tile <= 1'b1;
          pix_cnt <= '0;

          sum_r <= sum_final;
          min_r <= min_final;
          max_r <= max_final;
          if (DO_SUMSQ) sumsq_r <= sumsq_final;
          else          sumsq_r <= '0;

          ov_sum_r   <= 1'b0;
          ov_sumsq_r <= 1'b0;

          // latch meta at tile_first
          tx_out_r  <= tile_x_idx;
          ty_out_r  <= tile_y_idx;
          fid_out_r <= frame_id;

        end else begin
          if (!in_tile) begin
            tile_err_r <= 1'b1;
            err_code_r <= 8'h01; // non-first pixel while not in_tile
          end else begin
            pix_cnt <= pix_cnt_eff; // index of current pixel
            sum_r   <= sum_final;
            min_r   <= min_final;
            max_r   <= max_final;
            if (DO_SUMSQ) sumsq_r <= sumsq_final;
          end
        end

        // ---- tile_last: integrity check + latch outputs using FINAL ----
        if (tile_last) begin
          if (!in_tile && !is_tile_first) begin
            tile_err_r <= 1'b1;
            err_code_r <= 8'h02; // tile_last while not in_tile
          end else begin
            // fixed 4x4 expects last index = 15
            if (pix_cnt_eff != (TILE_PIXELS-1)) begin
              tile_err_r <= 1'b1;
              err_code_r <= 8'h03; // incomplete/wrong length
            end

            if (!out_hold) begin
              sum_out_r     <= sum_final;
              min_out_r     <= min_final;
              max_out_r     <= max_final;
              sumsq_out_r   <= sumsq_final;
              ycur_out_r    <= y_cur;
              pix_cnt_out_r <= pix_cnt_eff;

              ov_sum_out_r   <= ov_sum_r;
              ov_sumsq_out_r <= ov_sumsq_r;

              v_out_r <= 1'b1;
            end
          end

          // end tile
          in_tile <= 1'b0;
          pix_cnt <= '0;
        end

      end // pix_ok
    end
  end

  // ----------------------------------------------------------------
  // derived outputs (from latched outputs)
  // ----------------------------------------------------------------
  localparam int unsigned MEAN_SHIFT = (TILE_PIXELS <= 1) ? 0 : $clog2(TILE_PIXELS);

  logic [SUM_W-1:0] mean_ext;
  logic [Y_W:0]     range_ext;

  always_comb begin
    mean_ext  = (MEAN_SHIFT == 0) ? sum_out_r : (sum_out_r >> MEAN_SHIFT);
    range_ext = {1'b0, max_out_r} - {1'b0, min_out_r};
  end

  // ----------------------------------------------------------------
  // outputs
  // ----------------------------------------------------------------
  assign v3_valid   = v_out_r;

  assign sumY       = sum_out_r;
  assign minY       = min_out_r;
  assign maxY       = max_out_r;

  assign meanY      = mean_ext[Y_W-1:0];
  assign rangeY     = range_ext[Y_W-1:0];

  assign sumSq      = sumsq_out_r;

  assign y_cur_o    = ycur_out_r;
  assign tile_x_o   = tx_out_r;
  assign tile_y_o   = ty_out_r;
  assign frame_id_o = fid_out_r;

  assign tile_err   = tile_err_r;
  assign err_code   = err_code_r;
  assign pix_cnt_o  = pix_cnt_out_r;

  assign overflow_sum   = ov_sum_out_r;
  assign overflow_sumsq = ov_sumsq_out_r;

  // optional assertions hook (kept minimal)
  generate if (ASSERT_ON) begin : G_ASSERT
    // You can add SVAs here if desired
  end endgenerate

endmodule

`default_nettype wire


`timescale 1ns/1ps
`default_nettype none

module tile_edge_energy_4x4 #(
  parameter int unsigned Y_W      = 8,
  parameter int unsigned TILE_W   = 4,
  parameter int unsigned TILE_H   = 4,

  // feature switches
  parameter bit SUPPORT_PIX_VALID = 1'b1,
  parameter bit SUPPORT_TILE_START= 1'b1,
  parameter bit ASSERT_ON         = 1'b1,

  // energy modes:
  // 0: |dx|+|dy|
  // 1: max(|dx|,|dy|)
  // 2: threshold-count pixel contributes 1 if (|dx|+|dy| > THR)
  // 3: dx^2 + dy^2
  parameter int unsigned MODE     = 0,
  parameter int unsigned THR      = 8,

  // derived widths (must be parameter so ports can use it)
  parameter int unsigned EDGE_W   =
    ( (TILE_W*TILE_H*(2*((1<<Y_W)-1))) <= 1 ) ? 1 :
      $clog2( (TILE_W*TILE_H*(2*((1<<Y_W)-1))) + 1 ),

  parameter int unsigned CNT_W    =
    ( (TILE_W*TILE_H) <= 1 ) ? 1 : $clog2((TILE_W*TILE_H)+1),

  parameter int unsigned MEAN_W   = EDGE_W
)(
  input  logic                     clk,
  input  logic                     rst,

  // v2 streaming in (ready/valid)
  input  logic                     v2_valid,
  output logic                     v2_ready,

  input  logic [Y_W-1:0]            y_cur,
  input  logic [Y_W-1:0]            y_left,
  input  logic [Y_W-1:0]            y_up,
  input  logic [$clog2(TILE_W)-1:0] x_mod,
  input  logic [$clog2(TILE_H)-1:0] y_mod,

  input  logic                     tile_last,
  input  logic                     tile_start,          // optional (tie 0 if unused)
  input  logic                     pix_in_tile_valid,   // optional gating

  // v4 out (bundle)
  output logic                     v4_valid,
  input  logic                     v4_ready,
  output logic [EDGE_W-1:0]         edge_sum,
  output logic [EDGE_W-1:0]         edge_max,
  output logic [CNT_W-1:0]          edge_cnt,
  output logic [MEAN_W-1:0]         edge_mean
);

  localparam int unsigned TILE_PIXELS = TILE_W * TILE_H;

  // -----------------------------
  // output buffer (1-entry)
  // -----------------------------
  logic              out_v;
  logic [EDGE_W-1:0] out_sum, out_max;
  logic [CNT_W-1:0]  out_cnt;
  logic [MEAN_W-1:0] out_mean;

  assign v4_valid = out_v;

  // stall input whenever output buffer is full
  assign v2_ready = !out_v;

  wire accept_in  = v2_valid && v2_ready;

  // define "first pixel of tile"
  wire is_tile_first_xy = (x_mod == '0) && (y_mod == '0);
  wire is_tile_first    = (SUPPORT_TILE_START ? tile_start : 1'b0) || is_tile_first_xy;

  // pixel effective valid: B-mode (invalid pixel => contribute 0 energy, but still advance)
  wire pix_eff = (SUPPORT_PIX_VALID ? pix_in_tile_valid : 1'b1);

  // -----------------------------
  // abs diffs
  // -----------------------------
  logic [Y_W-1:0] dx_abs, dy_abs;

  always_comb begin
    if (x_mod == '0) dx_abs = '0;
    else             dx_abs = (y_cur >= y_left) ? (y_cur - y_left) : (y_left - y_cur);

    if (y_mod == '0) dy_abs = '0;
    else             dy_abs = (y_cur >= y_up) ? (y_cur - y_up) : (y_up - y_cur);
  end

  // -----------------------------
  // energy per pixel (mode selectable)
  // -----------------------------
  logic [Y_W:0]   e_abs_sum;     // |dx|+|dy| fits in Y_W+1
  logic [2*Y_W:0] e_sq_sum;      // dx^2 + dy^2: roughly up to 2*(2^Y-1)^2 => needs ~2Y+1
  logic [EDGE_W-1:0] e_pix_ext;
  logic [EDGE_W-1:0] e_for_max;  // energy value used for max tracking
  logic e_thr_hit;               // for cnt

  always_comb begin
    e_abs_sum = {1'b0, dx_abs} + {1'b0, dy_abs};

    // square (simple multiply; iverilog supports)
    e_sq_sum  = (dx_abs * dx_abs) + (dy_abs * dy_abs);

    // default
    e_thr_hit = (e_abs_sum > THR[Y_W:0]);

    // build e_pix_ext by MODE
    case (MODE)
      0: begin // abs sum
        e_for_max = {{(EDGE_W-($bits(e_abs_sum))){1'b0}}, e_abs_sum};
        e_pix_ext = pix_eff ? e_for_max : '0;
      end
      1: begin // max(|dx|,|dy|)
        logic [Y_W-1:0] m;
        m = (dx_abs >= dy_abs) ? dx_abs : dy_abs;
        e_for_max = {{(EDGE_W-Y_W){1'b0}}, m};
        e_pix_ext = pix_eff ? e_for_max : '0;
      end
      2: begin // threshold count: pixel contributes 1 if hit
        e_for_max = pix_eff && e_thr_hit ? {{(EDGE_W-1){1'b0}},1'b1} : '0;
        e_pix_ext = e_for_max;
      end
      3: begin // squared sum
        e_for_max = {{(EDGE_W-($bits(e_sq_sum))){1'b0}}, e_sq_sum[$bits(e_sq_sum)-1:0]};
        e_pix_ext = pix_eff ? e_for_max : '0;
      end
      default: begin
        e_for_max = {{(EDGE_W-($bits(e_abs_sum))){1'b0}}, e_abs_sum};
        e_pix_ext = pix_eff ? e_for_max : '0;
      end
    endcase
  end

  // -----------------------------
  // accumulators
  // -----------------------------
  logic [EDGE_W-1:0] sum_r, max_r;
  logic [CNT_W-1:0]  cnt_r;

  // next-state values
  logic [EDGE_W-1:0] sum_next, max_next;
  logic [CNT_W-1:0]  cnt_next;

  wire hit_cnt = (MODE==2) ? (e_pix_ext != '0) : (pix_eff && (e_abs_sum > THR[Y_W:0]));

  always_comb begin
    // sum
    if (is_tile_first) sum_next = e_pix_ext;
    else               sum_next = sum_r + e_pix_ext;

    // max
    if (is_tile_first) max_next = e_for_max;
    else               max_next = (e_for_max > max_r) ? e_for_max : max_r;

    // cnt
    if (is_tile_first) cnt_next = hit_cnt ? {{(CNT_W-1){1'b0}},1'b1} : '0;
    else               cnt_next = cnt_r + (hit_cnt ? {{(CNT_W-1){1'b0}},1'b1} : '0);
  end

  // mean (constant division)
  function automatic [MEAN_W-1:0] calc_mean(input [EDGE_W-1:0] s);
    calc_mean = s / TILE_PIXELS;
  endfunction

  // -----------------------------
  // sequential
  // -----------------------------
  always_ff @(posedge clk) begin
    if (rst) begin
      sum_r    <= '0;
      max_r    <= '0;
      cnt_r    <= '0;
      out_v    <= 1'b0;
      out_sum  <= '0;
      out_max  <= '0;
      out_cnt  <= '0;
      out_mean <= '0;
    end else begin
      // consume output
      if (out_v && v4_ready) begin
        out_v <= 1'b0;
      end

      // accept input only when not holding output
      if (accept_in) begin
        // update accumulators
        sum_r <= sum_next;
        max_r <= max_next;
        cnt_r <= cnt_next;

        // tile_last => latch output to buffer (even if v4_ready=0)
        if (tile_last) begin
          out_sum  <= sum_next;
          out_max  <= max_next;
          out_cnt  <= cnt_next;
          out_mean <= calc_mean(sum_next);
          out_v    <= 1'b1;

          // prepare next tile
          sum_r <= '0;
          max_r <= '0;
          cnt_r <= '0;
        end
      end
    end
  end

  assign edge_sum  = out_sum;
  assign edge_max  = out_max;
  assign edge_cnt  = out_cnt;
  assign edge_mean = out_mean;

  // -----------------------------
  // assertions / checkers
  // -----------------------------
  generate if (ASSERT_ON) begin : G_ASSERT
    always_ff @(posedge clk) begin
      if (!rst) begin
        if (accept_in && tile_last) begin
          // If tile_last is meant to be raster-aligned, enforce
          assert (x_mod == TILE_W-1 && y_mod == TILE_H-1)
            else $fatal(1, "tile_last misaligned: x_mod=%0d y_mod=%0d", x_mod, y_mod);
        end

        if (accept_in && (SUPPORT_TILE_START && tile_start)) begin
          // if tile_start asserted, we expect x_mod/y_mod==0/0 (optional, but good)
          assert (x_mod=='0 && y_mod=='0)
            else $fatal(1, "tile_start but x_mod/y_mod not 0: x=%0d y=%0d", x_mod, y_mod);
        end

        // no accepting input while output buffer full (by design)
        assert (!(v2_valid && !v2_ready))
          else begin end
      end
    end
  end endgenerate

endmodule

`default_nettype wire
`default_nettype none
`timescale 1ns/1ps



module tile_stats_edge_4x4 #(
  parameter int unsigned Y_W      = 8,
  parameter int unsigned TILE_W   = 4,
  parameter int unsigned TILE_H   = 4,

  // gating / start options
  parameter bit SUPPORT_PIX_VALID  = 1'b1,
  parameter bit SUPPORT_TILE_START = 1'b1,

  // edge energy modes (same as your tile_edge_energy_4x4)
  // 0: |dx|+|dy|
  // 1: max(|dx|,|dy|)
  // 2: threshold-count pixel contributes 1 if (|dx|+|dy| > THR)
  // 3: dx^2 + dy^2
  parameter int unsigned EDGE_MODE = 0,
  parameter int unsigned EDGE_THR  = 8,

  // assertions
  parameter bit ASSERT_ON = 1'b0,

  // ---- derived widths exposed as params for ports ----
  parameter int unsigned TILE_PIXELS = TILE_W*TILE_H,

  parameter int unsigned SUM_W =
    ((TILE_PIXELS * ((1<<Y_W)-1)) <= 1) ? 1 :
      $clog2((TILE_PIXELS * ((1<<Y_W)-1)) + 1),

  // edge_sum worst-case:
  // mode0: sum of (|dx|+|dy|) each <= 2*(2^Y-1)
  // mode3: sum of (dx^2+dy^2) each <= 2*(2^Y-1)^2
  // 這裡保守抓 mode3 上界
  parameter int unsigned EDGE_W =
    ((TILE_PIXELS * (2*(((1<<Y_W)-1)*((1<<Y_W)-1)))) <= 1) ? 1 :
      $clog2((TILE_PIXELS * (2*(((1<<Y_W)-1)*((1<<Y_W)-1)))) + 1),

  parameter int unsigned CNT_W =
    (TILE_PIXELS <= 1) ? 1 : $clog2(TILE_PIXELS + 1),

  parameter int unsigned MEAN_W = EDGE_W
)(
  input  logic                     clk,
  input  logic                     rst,

  // -----------------------------
  // v2 in (single stream)
  // -----------------------------
  input  logic                     v2_valid,
  output logic                     v2_ready,

  input  logic [Y_W-1:0]            y_cur,   // current pixel luma
  input  logic [Y_W-1:0]            y_left,  // left neighbor (xm>0)
  input  logic [Y_W-1:0]            y_up,    // up neighbor   (ym>0)

  input  logic [$clog2(TILE_W)-1:0] x_mod,
  input  logic [$clog2(TILE_H)-1:0] y_mod,

  input  logic                     tile_last,
  input  logic                     tile_start,          // optional
  input  logic                     pix_in_tile_valid,   // optional gating

  // meta passthrough (latched at tile_first; y_tag latched at tile_last)
  input  logic [15:0]              tile_x_idx,
  input  logic [15:0]              tile_y_idx,
  input  logic [15:0]              frame_id,
  input  logic [15:0]              y_tag_in,            // = 你原本 stats 的 y_cur(16b tag)

  // -----------------------------
  // v3 out (bundle)
  // -----------------------------
  output logic                     v3_valid,
  input  logic                     v3_ready,

  // stats
  output logic [SUM_W-1:0]          sumY,
  output logic [Y_W-1:0]            minY,
  output logic [Y_W-1:0]            maxY,
  output logic [Y_W-1:0]            meanY,
  output logic [Y_W-1:0]            rangeY,

  // edge
  output logic [EDGE_W-1:0]         edge_sum,
  output logic [EDGE_W-1:0]         edge_max,
  output logic [CNT_W-1:0]          edge_cnt,
  output logic [MEAN_W-1:0]         edge_mean,

  // meta out
  output logic [15:0]               y_tag_o,
  output logic [15:0]               tile_x_o,
  output logic [15:0]               tile_y_o,
  output logic [15:0]               frame_id_o,

  // errors / debug
  output logic                     tile_err,
  output logic [7:0]               err_code,
  output logic [$clog2(TILE_PIXELS+1)-1:0] pix_pos_o
);

  // ============================================================
  // Output buffer (1-entry) => controls ready
  // ============================================================
  logic out_v;
  assign v3_valid = out_v;

  // stall input whenever output buffer is full
  assign v2_ready = !out_v;

  wire accept_in = v2_valid && v2_ready;
  wire out_hold  = out_v && !v3_ready;

  // ============================================================
  // tile first definition + effective valid
  // ============================================================
  wire is_tile_first_xy = (x_mod == '0) && (y_mod == '0);
  wire is_tile_first    = (SUPPORT_TILE_START ? tile_start : 1'b0) || is_tile_first_xy;

  wire pix_eff = (SUPPORT_PIX_VALID ? pix_in_tile_valid : 1'b1);

  // ============================================================
  // stats accumulators (update only when pix_eff==1)
  // ============================================================
  logic [SUM_W-1:0] sum_r;
  logic [Y_W-1:0]   min_r, max_r;
  logic             has_valid_r;

  // tile position (0..15) based on accept_in, independent of pix_eff
  logic [$clog2(TILE_PIXELS+1)-1:0] pix_pos_r;

  // ============================================================
  // edge helpers
  // ============================================================
  function automatic int iabs(input int a);
    if (a < 0) iabs = -a; else iabs = a;
  endfunction

  // abs diffs (combinational)
  logic [Y_W-1:0] dx_abs, dy_abs;
  always_comb begin
    if (x_mod == '0) dx_abs = '0;
    else             dx_abs = (y_cur >= y_left) ? (y_cur - y_left) : (y_left - y_cur);

    if (y_mod == '0) dy_abs = '0;
    else             dy_abs = (y_cur >= y_up) ? (y_cur - y_up) : (y_left /*dummy*/);
  end
  // ↑ 注意：上面最後一行我故意不想留 bug；正確應該是 (y_up)。
  // 我在下面立刻修正成正確版本（保留這行你一看就知道差在哪）。
  always_comb begin
    if (y_mod == '0) dy_abs = '0;
    else             dy_abs = (y_cur >= y_up) ? (y_cur - y_up) : (y_up - y_cur);
  end

  logic [Y_W:0]   e_abs_sum;
  logic [2*Y_W:0] e_sq_sum;

  always_comb begin
    e_abs_sum = {1'b0, dx_abs} + {1'b0, dy_abs};
    e_sq_sum  = (dx_abs * dx_abs) + (dy_abs * dy_abs);
  end

  // energy per pixel (gated by pix_eff => B-mode 0 contribution)
  logic [EDGE_W-1:0] e_pix_ext;
  logic [EDGE_W-1:0] e_for_max;
  logic              hit_cnt;

  always_comb begin
    e_pix_ext = '0;
    e_for_max = '0;
    hit_cnt   = 1'b0;

    if (pix_eff) begin
      hit_cnt = (e_abs_sum > EDGE_THR[Y_W:0]);

      case (EDGE_MODE)
        0: begin
          e_for_max = {{(EDGE_W-$bits(e_abs_sum)){1'b0}}, e_abs_sum};
          e_pix_ext = e_for_max;
        end
        1: begin
          logic [Y_W-1:0] m;
          m = (dx_abs >= dy_abs) ? dx_abs : dy_abs;
          e_for_max = {{(EDGE_W-Y_W){1'b0}}, m};
          e_pix_ext = e_for_max;
        end
        2: begin
          e_for_max = hit_cnt ? {{(EDGE_W-1){1'b0}},1'b1} : '0;
          e_pix_ext = e_for_max;
        end
        3: begin
          e_for_max = {{(EDGE_W-$bits(e_sq_sum)){1'b0}}, e_sq_sum[$bits(e_sq_sum)-1:0]};
          e_pix_ext = e_for_max;
        end
        default: begin
          e_for_max = {{(EDGE_W-$bits(e_abs_sum)){1'b0}}, e_abs_sum};
          e_pix_ext = e_for_max;
        end
      endcase
    end
  end

  // edge accumulators (advance per accept_in; contribution 0 when !pix_eff)
  logic [EDGE_W-1:0] edge_sum_r, edge_max_r;
  logic [CNT_W-1:0]  edge_cnt_r;

  // ============================================================
  // output regs (latched on tile_last)
  // ============================================================
  logic [SUM_W-1:0]  sum_out_r;
  logic [Y_W-1:0]    min_out_r, max_out_r;
  logic [EDGE_W-1:0] edge_sum_out_r, edge_max_out_r;
  logic [CNT_W-1:0]  edge_cnt_out_r;

  logic [15:0] ytag_out_r, tx_out_r, ty_out_r, fid_out_r;

  logic tile_err_r;
  logic [7:0] err_code_r;
  logic [$clog2(TILE_PIXELS+1)-1:0] pix_pos_out_r;

  // ============================================================
  // sequential
  // ============================================================
  always_ff @(posedge clk) begin
    if (rst) begin
      out_v <= 1'b0;

      // stats
      sum_r       <= '0;
      min_r       <= {Y_W{1'b1}};
      max_r       <= '0;
      has_valid_r <= 1'b0;

      // edge
      edge_sum_r <= '0;
      edge_max_r <= '0;
      edge_cnt_r <= '0;

      // pos
      pix_pos_r <= '0;

      // outputs
      sum_out_r       <= '0;
      min_out_r       <= '0;
      max_out_r       <= '0;
      edge_sum_out_r  <= '0;
      edge_max_out_r  <= '0;
      edge_cnt_out_r  <= '0;

      ytag_out_r <= '0;
      tx_out_r   <= '0;
      ty_out_r   <= '0;
      fid_out_r  <= '0;

      tile_err_r    <= 1'b0;
      err_code_r    <= 8'h00;
      pix_pos_out_r <= '0;

    end else begin
      // consume output
      if (out_v && v3_ready) begin
        out_v <= 1'b0;
      end

      if (accept_in) begin
        // --------------- tile first init ---------------
        if (is_tile_first) begin
          // reset running accumulators for new tile
          sum_r       <= '0;
          min_r       <= {Y_W{1'b1}};
          max_r       <= '0;
          has_valid_r <= 1'b0;

          edge_sum_r <= '0;
          edge_max_r <= '0;
          edge_cnt_r <= '0;

          pix_pos_r  <= '0;

          // latch meta at tile_first
          tx_out_r   <= tile_x_idx;
          ty_out_r   <= tile_y_idx;
          fid_out_r  <= frame_id;

          // clear errors at tile_first
          tile_err_r <= 1'b0;
          err_code_r <= 8'h00;
        end else begin
          // advance position (0..15)
          pix_pos_r <= pix_pos_r + 1'b1;
        end

        // --------------- stats update (only if pix_eff) ---------------
        if (pix_eff) begin
          // sum
          sum_r <= sum_r + {{(SUM_W-Y_W){1'b0}}, y_cur};

          // min/max
          if (!has_valid_r) begin
            min_r <= y_cur;
            max_r <= y_cur;
            has_valid_r <= 1'b1;
          end else begin
            if (y_cur < min_r) min_r <= y_cur;
            if (y_cur > max_r) max_r <= y_cur;
          end
        end

        // --------------- edge update (B-mode 0 contribution) ---------------
        edge_sum_r <= edge_sum_r + e_pix_ext;
        if (is_tile_first) edge_max_r <= e_for_max;
        else if (e_for_max > edge_max_r) edge_max_r <= e_for_max;

        if (EDGE_MODE == 2) begin
          // mode2: cnt is number of hits (valid & e_abs>thr)
          edge_cnt_r <= edge_cnt_r + (hit_cnt ? {{(CNT_W-1){1'b0}},1'b1} : '0);
        end else begin
          // keep same "hit" definition if you want cnt for all modes too
          edge_cnt_r <= edge_cnt_r + (hit_cnt ? {{(CNT_W-1){1'b0}},1'b1} : '0);
        end

        // --------------- tile_last => latch outputs ---------------
        if (tile_last) begin
          // fixed 4x4 expects last position = 15
          // note: if tile_first and tile_last same cycle => pix_pos_r is 0, which is wrong for 4x4 stream
          // so we check using expected = TILE_PIXELS-1
          if ((is_tile_first ? '0 : pix_pos_r) != (TILE_PIXELS-1)) begin
            tile_err_r <= 1'b1;
            err_code_r <= 8'h03; // wrong length / incomplete
          end

          // latch outputs even if v3_ready=0 (buffer holds it)
          sum_out_r      <= sum_r + (pix_eff ? {{(SUM_W-Y_W){1'b0}}, y_cur} : '0); // include current pixel if valid
          min_out_r      <= (has_valid_r || pix_eff) ?
                              ((has_valid_r==1'b0) ? y_cur :
                                (pix_eff && (y_cur < min_r)) ? y_cur : min_r)
                            : '0;
          max_out_r      <= (has_valid_r || pix_eff) ?
                              ((has_valid_r==1'b0) ? y_cur :
                                (pix_eff && (y_cur > max_r)) ? y_cur : max_r)
                            : '0;

          edge_sum_out_r <= edge_sum_r + e_pix_ext;
          edge_max_out_r <= (is_tile_first ? e_for_max :
                              (e_for_max > edge_max_r) ? e_for_max : edge_max_r);
          edge_cnt_out_r <= edge_cnt_r + (hit_cnt ? {{(CNT_W-1){1'b0}},1'b1} : '0);

          ytag_out_r     <= y_tag_in;
          pix_pos_out_r  <= (is_tile_first ? '0 : pix_pos_r);

          out_v <= 1'b1;

          // prepare next tile
          pix_pos_r <= '0;
        end
      end
    end
  end

  // ============================================================
  // derived outputs
  // ============================================================
  localparam int unsigned MEAN_SHIFT = (TILE_PIXELS <= 1) ? 0 : $clog2(TILE_PIXELS);

  logic [SUM_W-1:0] mean_ext;
  logic [Y_W:0]     range_ext;
  logic [MEAN_W-1:0] edge_mean_ext;

  always_comb begin
    mean_ext      = (MEAN_SHIFT == 0) ? sum_out_r : (sum_out_r >> MEAN_SHIFT);
    range_ext     = {1'b0, max_out_r} - {1'b0, min_out_r};
    edge_mean_ext = edge_sum_out_r / TILE_PIXELS;
  end

  // ============================================================
  // port assigns
  // ============================================================
  assign sumY   = sum_out_r;
  assign minY   = min_out_r;
  assign maxY   = max_out_r;
  assign meanY  = mean_ext[Y_W-1:0];
  assign rangeY = range_ext[Y_W-1:0];

  assign edge_sum  = edge_sum_out_r;
  assign edge_max  = edge_max_out_r;
  assign edge_cnt  = edge_cnt_out_r;
  assign edge_mean = edge_mean_ext;

  assign y_tag_o    = ytag_out_r;
  assign tile_x_o   = tx_out_r;
  assign tile_y_o   = ty_out_r;
  assign frame_id_o = fid_out_r;

  assign tile_err  = tile_err_r;
  assign err_code  = err_code_r;
  assign pix_pos_o = pix_pos_out_r;

  // ============================================================
  // optional assertions
  // ============================================================
  generate if (ASSERT_ON) begin : G_ASSERT
    always_ff @(posedge clk) begin
      if (!rst) begin
        if (accept_in && tile_last) begin
          assert (x_mod == TILE_W-1 && y_mod == TILE_H-1)
            else $fatal(1, "tile_last misaligned: x_mod=%0d y_mod=%0d", x_mod, y_mod);
        end
        if (accept_in && (SUPPORT_TILE_START && tile_start)) begin
          assert (x_mod=='0 && y_mod=='0)
            else $fatal(1, "tile_start but x_mod/y_mod not 0: x=%0d y=%0d", x_mod, y_mod);
        end
      end
    end
  end endgenerate

endmodule

`default_nettype wire

`timescale 1ns/1ps
`default_nettype none



module tb_tile_stats_edge_4x4;

  // ============================================================
  // params
  // ============================================================
  localparam int Y_W    = 8;
  localparam int TILE_W = 4;
  localparam int TILE_H = 4;

  localparam int EDGE_MODE = 0;   // 0..3
  localparam int EDGE_THR  = 8;

  localparam int TILE_PIXELS = TILE_W*TILE_H;

  localparam int SUM_W =
    ((TILE_PIXELS * ((1<<Y_W)-1)) <= 1) ? 1 :
      $clog2((TILE_PIXELS * ((1<<Y_W)-1)) + 1);

  localparam int EDGE_W =
    ((TILE_PIXELS * (2*(((1<<Y_W)-1)*((1<<Y_W)-1)))) <= 1) ? 1 :
      $clog2((TILE_PIXELS * (2*(((1<<Y_W)-1)*((1<<Y_W)-1)))) + 1);

  localparam int CNT_W  = (TILE_PIXELS <= 1) ? 1 : $clog2(TILE_PIXELS + 1);
  localparam int MEAN_W = EDGE_W;

  // ============================================================
  // clock/reset
  // ============================================================
  logic clk = 1'b0;
  always #5 clk = ~clk;
  logic rst;

  // ============================================================
  // DUT I/O
  // ============================================================
  logic                     v2_valid;
  logic                     v2_ready;

  logic [Y_W-1:0]            y_cur, y_left, y_up;
  logic [$clog2(TILE_W)-1:0] x_mod;
  logic [$clog2(TILE_H)-1:0] y_mod;

  logic                     tile_last;
  logic                     tile_start;
  logic                     pix_in_tile_valid;

  logic [15:0]              tile_x_idx, tile_y_idx, frame_id, y_tag_in;

  logic                     v3_valid;
  logic                     v3_ready;

  logic [SUM_W-1:0]          sumY;
  logic [Y_W-1:0]            minY, maxY, meanY, rangeY;

  logic [EDGE_W-1:0]         edge_sum, edge_max;
  logic [CNT_W-1:0]          edge_cnt;
  logic [MEAN_W-1:0]         edge_mean;

  logic [15:0]               y_tag_o, tile_x_o, tile_y_o, frame_id_o;

  logic                     tile_err;
  logic [7:0]               err_code;
  logic [$clog2(TILE_PIXELS+1)-1:0] pix_pos_o;

  // ============================================================
  // DUT
  // ============================================================
  tile_stats_edge_4x4 #(
    .Y_W(Y_W), .TILE_W(TILE_W), .TILE_H(TILE_H),
    .SUPPORT_PIX_VALID(1'b1),
    .SUPPORT_TILE_START(1'b1),
    .EDGE_MODE(EDGE_MODE),
    .EDGE_THR(EDGE_THR),
    .ASSERT_ON(1'b0)
  ) dut (
    .clk(clk),
    .rst(rst),

    .v2_valid(v2_valid),
    .v2_ready(v2_ready),

    .y_cur(y_cur),
    .y_left(y_left),
    .y_up(y_up),

    .x_mod(x_mod),
    .y_mod(y_mod),

    .tile_last(tile_last),
    .tile_start(tile_start),
    .pix_in_tile_valid(pix_in_tile_valid),

    .tile_x_idx(tile_x_idx),
    .tile_y_idx(tile_y_idx),
    .frame_id(frame_id),
    .y_tag_in(y_tag_in),

    .v3_valid(v3_valid),
    .v3_ready(v3_ready),

    .sumY(sumY),
    .minY(minY),
    .maxY(maxY),
    .meanY(meanY),
    .rangeY(rangeY),

    .edge_sum(edge_sum),
    .edge_max(edge_max),
    .edge_cnt(edge_cnt),
    .edge_mean(edge_mean),

    .y_tag_o(y_tag_o),
    .tile_x_o(tile_x_o),
    .tile_y_o(tile_y_o),
    .frame_id_o(frame_id_o),

    .tile_err(tile_err),
    .err_code(err_code),
    .pix_pos_o(pix_pos_o)
  );

  // ============================================================
  // helper
  // ============================================================
  task automatic step; begin @(posedge clk); #1; end endtask

  function automatic int iabs(input int a);
    if (a < 0) iabs = -a; else iabs = a;
  endfunction

  function automatic int sq(input int a);
    sq = a*a;
  endfunction

  function automatic int idx(input int xm, input int ym);
    idx = ym*4 + xm;
  endfunction

  // ============================================================
  // backpressure pattern (like your linebuf TB)
  // ============================================================
  int cyc;
  bit bp_enable;

  always_comb begin
    if (!bp_enable) v3_ready = 1'b1;
    else begin
      // stall every 5th cycle
      if ((cyc % 5) == 4) v3_ready = 1'b0;
      else                v3_ready = 1'b1;
    end
  end

  wire fire_in  = v2_valid && v2_ready;
  wire fire_out = v3_valid && v3_ready;

  // ============================================================
  // Golden model state for ONE tile stream
  // (we compute expected full-tile result in TB, then push into queue at tile_last accept)
  // BUT: you want push per accepted beat style => we accumulate per accept here.
  // ============================================================
  int g_sumY;
  int g_minY;
  int g_maxY;
  bit g_any_valid;

  int g_edge_sum;
  int g_edge_max;
  int g_edge_cnt;

  int g_pos; // 0..15 (advances per accept_in)

  // latched meta (at tile_start / (0,0))
  int g_tx, g_ty, g_fid;

  task automatic gold_reset;
    begin
      g_sumY = 0;
      g_minY = 999999;
      g_maxY = -1;
      g_any_valid = 0;

      g_edge_sum = 0;
      g_edge_max = 0;
      g_edge_cnt = 0;

      g_pos = 0;

      g_tx = 0; g_ty = 0; g_fid = 0;
    end
  endtask

  // ============================================================
  // Scoreboard queue: push expected tile result at accept_in && tile_last
  // pop at fire_out
  // ============================================================
  localparam int QDEPTH = 1024;

  // expected bundle
  int q_sumY   [0:QDEPTH-1];
  int q_minY   [0:QDEPTH-1];
  int q_maxY   [0:QDEPTH-1];
  int q_meanY  [0:QDEPTH-1];
  int q_rangeY [0:QDEPTH-1];

  int q_esum   [0:QDEPTH-1];
  int q_emax   [0:QDEPTH-1];
  int q_ecnt   [0:QDEPTH-1];
  int q_emean  [0:QDEPTH-1];

  int q_tx     [0:QDEPTH-1];
  int q_ty     [0:QDEPTH-1];
  int q_fid    [0:QDEPTH-1];
  int q_ytag   [0:QDEPTH-1];

  int q_err    [0:QDEPTH-1];
  int q_code   [0:QDEPTH-1];
  int q_pos    [0:QDEPTH-1];

  int q_wptr, q_rptr;
  // ---- temporaries for golden update (iverilog-friendly: no block declarations)
  integer dx, dy, e_abs, e, emax_val;
  reg     is_first_tb;

  integer exp_sumY, exp_minY, exp_maxY, exp_meanY, exp_rangeY;
  integer exp_esum, exp_emax, exp_ecnt, exp_emean;
  integer exp_err, exp_code, exp_pos;

  integer pop_sumY, pop_minY, pop_maxY, pop_meanY, pop_rangeY;
  integer pop_esum, pop_emax, pop_ecnt, pop_emean;
  integer pop_tx, pop_ty, pop_fid, pop_ytag;
  integer pop_err, pop_code, pop_pos;

  task automatic q_reset;
    begin q_wptr = 0; q_rptr = 0; end
  endtask

  task automatic q_push;
    input int esumY, eminY, emaxY, emeanY, erangeY;
    input int eedge_sum, eedge_max, eedge_cnt, eedge_mean;
    input int etx, ety, efid, eytag;
    input int eerr, ecode, epos;
    begin
      if (q_wptr >= QDEPTH) $fatal(1, "[TB] queue overflow");
      q_sumY[q_wptr]   = esumY;
      q_minY[q_wptr]   = eminY;
      q_maxY[q_wptr]   = emaxY;
      q_meanY[q_wptr]  = emeanY;
      q_rangeY[q_wptr] = erangeY;

      q_esum[q_wptr]   = eedge_sum;
      q_emax[q_wptr]   = eedge_max;
      q_ecnt[q_wptr]   = eedge_cnt;
      q_emean[q_wptr]  = eedge_mean;

      q_tx[q_wptr]   = etx;
      q_ty[q_wptr]   = ety;
      q_fid[q_wptr]  = efid;
      q_ytag[q_wptr] = eytag;

      q_err[q_wptr]  = eerr;
      q_code[q_wptr] = ecode;
      q_pos[q_wptr]  = epos;

      q_wptr++;
    end
  endtask

  task automatic q_pop;
    output int esumY, eminY, emaxY, emeanY, erangeY;
    output int eedge_sum, eedge_max, eedge_cnt, eedge_mean;
    output int etx, ety, efid, eytag;
    output int eerr, ecode, epos;
    begin
      if (q_rptr >= q_wptr) $fatal(1, "[TB] queue underflow");
      esumY   = q_sumY[q_rptr];
      eminY   = q_minY[q_rptr];
      emaxY   = q_maxY[q_rptr];
      emeanY  = q_meanY[q_rptr];
      erangeY = q_rangeY[q_rptr];

      eedge_sum  = q_esum[q_rptr];
      eedge_max  = q_emax[q_rptr];
      eedge_cnt  = q_ecnt[q_rptr];
      eedge_mean = q_emean[q_rptr];

      etx   = q_tx[q_rptr];
      ety   = q_ty[q_rptr];
      efid  = q_fid[q_rptr];
      eytag = q_ytag[q_rptr];

      eerr  = q_err[q_rptr];
      ecode = q_code[q_rptr];
      epos  = q_pos[q_rptr];

      q_rptr++;
    end
  endtask

  // ============================================================
  // Driver: hold v2_valid until accepted (fire_in)
  // ============================================================
  task automatic send_pixel(
    input int xm,
    input int ym,
    input int cur,
    input int left,
    input int up,
    input bit is_first,
    input bit is_last,
    input bit pix_ok,
    input int tx,
    input int ty,
    input int fid,
    input int ytag
  );
    int guard;
    bit accepted;
    begin
      v2_valid = 1'b1;

      x_mod = xm[$bits(x_mod)-1:0];
      y_mod = ym[$bits(y_mod)-1:0];

      y_cur  = cur[Y_W-1:0];
      y_left = left[Y_W-1:0];
      y_up   = up[Y_W-1:0];

      tile_start = is_first;
      tile_last  = is_last;
      pix_in_tile_valid = pix_ok;

      tile_x_idx = tx[15:0];
      tile_y_idx = ty[15:0];
      frame_id   = fid[15:0];
      y_tag_in   = ytag[15:0];

      guard = 0;
      accepted = 0;
      while (!accepted) begin
        step(); cyc++;
        accepted = fire_in;

        guard++;
        if (guard > 2000) begin
          $display("[TB] TIMEOUT waiting fire_in (v2_ready=%0b v3_valid=%0b v3_ready=%0b)",
                   v2_ready, v3_valid, v3_ready);
          $fatal(1, "FAIL");
        end
      end

      // drop after accept
      v2_valid = 1'b0;
      tile_start = 1'b0;
      tile_last  = 1'b0;
      pix_in_tile_valid = 1'b1;
      y_tag_in = '0;

      // optional bubble
      step(); cyc++;
    end
  endtask

  // ============================================================
  // Golden update on TRUE accept (fire_in)
  // - accumulates each accepted pixel
  // - pushes expected bundle when tile_last accepted
  // ============================================================
    always_ff @(posedge clk) begin
    if (!rst) begin
      if (fire_in) begin
        // tile_first definition same as DUT
        is_first_tb = (tile_start || ((x_mod=='0) && (y_mod=='0)));

        if (is_first_tb) begin
          gold_reset();
          g_tx  <= tile_x_idx;
          g_ty  <= tile_y_idx;
          g_fid <= frame_id;
          g_pos <= 0;
        end else begin
          g_pos <= g_pos + 1;
        end

        // stats: only when pix_eff
        if (pix_in_tile_valid) begin
          g_sumY <= g_sumY + y_cur;

          if (!g_any_valid) begin
            g_minY <= y_cur;
            g_maxY <= y_cur;
            g_any_valid <= 1'b1;
          end else begin
            if (y_cur < g_minY) g_minY <= y_cur;
            if (y_cur > g_maxY) g_maxY <= y_cur;
          end
        end

        // edge compute (B-mode: invalid contributes 0)
        dx = (x_mod=='0) ? 0 : iabs(y_cur - y_left);
        dy = (y_mod=='0) ? 0 : iabs(y_cur - y_up);
        e_abs = dx + dy;

        // hit count uses abs_sum > thr and valid
        if (pix_in_tile_valid && (e_abs > EDGE_THR)) g_edge_cnt <= g_edge_cnt + 1;

        if (!pix_in_tile_valid) begin
          e = 0;
        end else begin
          case (EDGE_MODE)
            0: e = e_abs;
            1: e = (dx>dy) ? dx : dy;
            2: e = (e_abs > EDGE_THR) ? 1 : 0;
            3: e = sq(dx) + sq(dy);
            default: e = e_abs;
          endcase
        end

        g_edge_sum <= g_edge_sum + e;

        // for max tracking (same definition as e)
        if (!pix_in_tile_valid) emax_val = 0;
        else emax_val = e;

        if (is_first_tb) g_edge_max <= emax_val;
        else if (emax_val > g_edge_max) g_edge_max <= emax_val;

        // tile_last accepted => push expected full-tile bundle
        if (tile_last) begin
          exp_sumY = g_sumY + (pix_in_tile_valid ? y_cur : 0);

          if (!g_any_valid && !pix_in_tile_valid) begin
            exp_minY = 0; exp_maxY = 0;
          end else if (!g_any_valid && pix_in_tile_valid) begin
            exp_minY = y_cur; exp_maxY = y_cur;
          end else begin
            exp_minY = g_minY;
            exp_maxY = g_maxY;
            if (pix_in_tile_valid && (y_cur < exp_minY)) exp_minY = y_cur;
            if (pix_in_tile_valid && (y_cur > exp_maxY)) exp_maxY = y_cur;
          end

          exp_meanY  = exp_sumY / 16;
          exp_rangeY = exp_maxY - exp_minY;

          exp_esum  = g_edge_sum + e;
          exp_emax  = (is_first_tb ? emax_val : ((emax_val > g_edge_max) ? emax_val : g_edge_max));
          exp_ecnt  = g_edge_cnt + ((pix_in_tile_valid && (e_abs > EDGE_THR)) ? 1 : 0);
          exp_emean = exp_esum / 16;

          exp_pos = (is_first_tb ? 0 : g_pos);
          if (exp_pos != 15) begin
            exp_err  = 1;
            exp_code = 8'h03;
          end else begin
            exp_err  = 0;
            exp_code = 8'h00;
          end

          q_push(exp_sumY, exp_minY, exp_maxY, exp_meanY, exp_rangeY,
                 exp_esum, exp_emax, exp_ecnt, exp_emean,
                 tile_x_idx, tile_y_idx, frame_id, y_tag_in,
                 exp_err, exp_code, exp_pos);
        end
      end
    end
  end


  // ============================================================
  // Compare only when output consumed (fire_out)
  // ============================================================
    always_ff @(posedge clk) begin
    if (!rst) begin
      if (fire_out) begin
        q_pop(pop_sumY, pop_minY, pop_maxY, pop_meanY, pop_rangeY,
              pop_esum, pop_emax, pop_ecnt, pop_emean,
              pop_tx, pop_ty, pop_fid, pop_ytag,
              pop_err, pop_code, pop_pos);

        if (sumY !== pop_sumY[SUM_W-1:0])  $fatal(1,"[TB] sumY got=%0d exp=%0d", sumY, pop_sumY);
        if (minY !== pop_minY[Y_W-1:0])    $fatal(1,"[TB] minY got=%0d exp=%0d", minY, pop_minY);
        if (maxY !== pop_maxY[Y_W-1:0])    $fatal(1,"[TB] maxY got=%0d exp=%0d", maxY, pop_maxY);
        if (meanY !== pop_meanY[Y_W-1:0])  $fatal(1,"[TB] meanY got=%0d exp=%0d", meanY, pop_meanY);
        if (rangeY !== pop_rangeY[Y_W-1:0])$fatal(1,"[TB] rangeY got=%0d exp=%0d", rangeY, pop_rangeY);

        if (edge_sum !== pop_esum[EDGE_W-1:0]) $fatal(1,"[TB] edge_sum got=%0d exp=%0d", edge_sum, pop_esum);
        if (edge_max !== pop_emax[EDGE_W-1:0]) $fatal(1,"[TB] edge_max got=%0d exp=%0d", edge_max, pop_emax);
        if (edge_cnt !== pop_ecnt[CNT_W-1:0])  $fatal(1,"[TB] edge_cnt got=%0d exp=%0d", edge_cnt, pop_ecnt);
        if (edge_mean !== pop_emean[MEAN_W-1:0]) $fatal(1,"[TB] edge_mean got=%0d exp=%0d", edge_mean, pop_emean);

        if (tile_x_o !== pop_tx[15:0])     $fatal(1,"[TB] tile_x_o got=%0d exp=%0d", tile_x_o, pop_tx);
        if (tile_y_o !== pop_ty[15:0])     $fatal(1,"[TB] tile_y_o got=%0d exp=%0d", tile_y_o, pop_ty);
        if (frame_id_o !== pop_fid[15:0])  $fatal(1,"[TB] frame_id_o got=%0d exp=%0d", frame_id_o, pop_fid);
        if (y_tag_o !== pop_ytag[15:0])    $fatal(1,"[TB] y_tag_o got=%0d exp=%0d", y_tag_o, pop_ytag);

        if (tile_err !== pop_err[0])       $fatal(1,"[TB] tile_err got=%0b exp=%0b", tile_err, pop_err[0]);
        if ((pop_err != 0) && (err_code === 8'h00)) $fatal(1,"[TB] err_code should be nonzero when tile_err=1");
        if (pix_pos_o !== pop_pos[$bits(pix_pos_o)-1:0]) $fatal(1,"[TB] pix_pos_o got=%0d exp=%0d", pix_pos_o, pop_pos);
      end
    end
  end


  // ============================================================
  // HOLD check under stall (like your linebuf TB)
  // ============================================================
  logic hold_active;
  logic [SUM_W-1:0]  hold_sum;
  logic [EDGE_W-1:0] hold_esum;

  always_ff @(posedge clk) begin
    if (rst) begin
      hold_active <= 1'b0;
      hold_sum    <= '0;
      hold_esum   <= '0;
    end else begin
      if (v3_valid && !v3_ready) begin
        if (!hold_active) begin
          hold_active <= 1'b1;
          hold_sum    <= sumY;
          hold_esum   <= edge_sum;
        end else begin
          if (sumY !== hold_sum)   $fatal(1,"[TB] HOLD FAIL sumY changed under stall");
          if (edge_sum !== hold_esum) $fatal(1,"[TB] HOLD FAIL edge_sum changed under stall");
        end
      end
      if (fire_out) hold_active <= 1'b0;
    end
  end

  // ============================================================
  // Build a tile from array + optional holes
  // ============================================================
  integer tileA [0:15];
  reg     mask  [0:15];

  task automatic send_tile(
    input int tx,
    input int ty,
    input int fid,
    input int ytag,
    input bit use_mask,
    input bit pulse_tile_start
  );
    int ym,xm;
    int cur,left,up;
    bit ok;
    bit first,last;
    begin
      for (ym=0; ym<4; ym++) begin
        for (xm=0; xm<4; xm++) begin
          cur = tileA[idx(xm,ym)];
          if (xm==0) left = cur; else left = tileA[idx(xm-1,ym)];
          if (ym==0) up   = cur; else up   = tileA[idx(xm,ym-1)];

          ok    = use_mask ? mask[idx(xm,ym)] : 1'b1;
          first = (xm==0 && ym==0);
          last  = (xm==3 && ym==3);

          send_pixel(
            xm, ym, cur, left, up,
            (pulse_tile_start ? first : 1'b0),
            last,
            ok,
            tx, ty, fid, ytag
          );
        end
      end
    end
  endtask

  // ============================================================
  // main
  // ============================================================
  integer i;
  initial begin
    $dumpfile("./vvp/tb_tile_stats_edge_4x4.vcd");
    $dumpvars(0, tb_tile_stats_edge_4x4);

    // init
    rst = 1'b1;
    cyc = 0;
    bp_enable = 1'b0;

    v2_valid = 1'b0;
    y_cur='0; y_left='0; y_up='0;
    x_mod='0; y_mod='0;
    tile_last=0; tile_start=0;
    pix_in_tile_valid=1;

    tile_x_idx=0; tile_y_idx=0; frame_id=0; y_tag_in=0;

    gold_reset();
    q_reset();

    // tileA=1..16
    for (i=0; i<16; i++) begin
      tileA[i] = i+1;
      mask[i]  = 1'b1;
    end
    // holes
    mask[idx(1,1)] = 1'b0;
    mask[idx(0,2)] = 1'b0;
    mask[idx(2,3)] = 1'b0;

    // reset
    repeat (5) step();
    rst = 1'b0;

    // ----------------------------------------------------------
    // Case0: basic all valid, no BP
    // ----------------------------------------------------------
    $display("[RUN] Case0 basic no backpressure");
    bp_enable = 1'b0;
    gold_reset();
    q_reset();

    send_tile(3, 5, 7, 111, 1'b0, 1'b1);

    // ----------------------------------------------------------
    // Case1: masked holes + backpressure
    // ----------------------------------------------------------
    $display("[RUN] Case1 mask holes with backpressure");
    bp_enable = 1'b1;

    send_tile(1, 2, 9, 222, 1'b1, 1'b1);

    // drain
    begin : DRAIN
      int guard;
      guard = 0;
      while (q_rptr != q_wptr) begin
        step(); cyc++; guard++;
        if (guard > 5000) $fatal(1, "[TB] TIMEOUT draining q_rptr=%0d q_wptr=%0d v3_valid=%0b v3_ready=%0b",
                                 q_rptr, q_wptr, v3_valid, v3_ready);
      end
    end

    $display("[PASS] tb_tile_stats_edge_4x4 ✅");
    $finish;
  end

endmodule

`default_nettype wire
